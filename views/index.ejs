<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Request Explorer - Home</title>
    <link href="/styles.css" rel="stylesheet" type="text/css" />
  </head>
  <body class="bg-gray-50">
    <div class="container mx-auto px-4 py-12">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold mb-3">Welcome to Request Explorer</h1>
        <p class="text-xl text-gray-600">Quickly inspect and manage your HTTP requests.</p>
      </div>
      <div class="bg-white rounded-lg shadow-md mt-5">
        <div class="p-6">
          <h2 class="text-2xl font-semibold mb-4">Your Request Explorer URL</h2>
          <p class="text-gray-700">
            Access your explorer at:
            <a href="/r/<%= uniqueId %>" class="font-bold text-blue-600 hover:text-blue-800"><%= origin %>/r/<%= uniqueId %></a>
          </p>
        </div>
      </div>
      <div class="bg-white rounded-lg shadow-md mt-4">
        <div class="p-6">
          <h2 class="text-2xl font-semibold mb-4">Stored URLs (Client-Side)</h2>
          <div id="storedUrls" class="mt-3">Loading stored URLs...</div>
        </div>
      </div>
    </div>
    <script src="/js/index.js"></script>
  </body>
</html>
