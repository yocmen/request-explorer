<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Request Explorer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  </head>
  <body class="bg-light">
    <div class="container p-5">
      <h1 class="mb-4">Request Explorer</h1>
      <p>Your unique URL to receive requests is:</p>
      <div class="alert alert-info">
        <a href="/r/<%= uniqueId %>" class="stretched-link">http://localhost:3000/r/<%= uniqueId %></a>
      </div>
      <p>Share this URL to receive and explore incoming requests.</p>
      <hr />
      <h2>Previously Used URLs</h2>
      <div id="storedUrls">
        <!-- Previously used URLs will be listed here -->
      </div>
    </div>
    <script>
      // Open IndexedDB (same dbName, version, and objectStore as in explorer.ejs)
      function openDB() {
        return new Promise((resolve, reject) => {
          const request = indexedDB.open("RequestDB", 2);
          request.onerror = () => reject("Error opening IndexedDB.");
          request.onsuccess = () => resolve(request.result);
          request.onupgradeneeded = (event) => {
            const db = event.target.result;
            if (!db.objectStoreNames.contains("requests")) {
              const store = db.createObjectStore("requests", { keyPath: "id" });
              store.createIndex("roomIdx", "room", { unique: false });
            }
          };
        });
      }

      // Retrieve all stored requests and deduplicate room ids.
      function getDistinctRooms() {
        return openDB().then((db) => {
          return new Promise((resolve, reject) => {
            const tx = db.transaction("requests", "readonly");
            const store = tx.objectStore("requests");
            const request = store.getAll();
            request.onsuccess = () => {
              const rooms = new Set();
              request.result.forEach((item) => {
                if (item.room) rooms.add(item.room);
              });
              resolve(Array.from(rooms));
            };
            request.onerror = () => reject("Error fetching requests.");
          });
        });
      }

      document.addEventListener("DOMContentLoaded", () => {
        getDistinctRooms()
          .then((rooms) => {
            const container = document.getElementById("storedUrls");
            if (rooms.length > 0) {
              rooms.forEach((room) => {
                const link = document.createElement("a");
                link.href = "/r/" + room;
                link.textContent = "http://localhost:3000/r/" + room;
                link.classList.add("d-block");
                container.appendChild(link);
              });
            } else {
              container.textContent = "No previously used URLs.";
            }
          })
          .catch((err) => console.error(err));
      });
    </script>
  </body>
</html>
