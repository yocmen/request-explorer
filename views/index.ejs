<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Request Explorer - Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      .card {
        margin-top: 20px;
      }
    </style>
  </head>
  <body>
    <div class="container py-5">
      <div class="text-center mb-5">
        <h1 class="display-4">Welcome to Request Explorer</h1>
        <p class="lead">Quickly inspect and manage your HTTP requests.</p>
      </div>
      <div class="card">
        <div class="card-body">
          <h2 class="card-title">Your Request Explorer URL</h2>
          <p class="card-text">
            Access your explorer at:
            <a href="/r/<%= uniqueId %>" class="fw-bold"><%= origin %>/r/<%= uniqueId %></a>
          </p>
        </div>
      </div>
      <div class="card mt-4">
        <div class="card-body">
          <h2 class="card-title">Stored URLs (Client-Side)</h2>
          <div id="storedUrls" class="mt-3">Loading stored URLs...</div>
        </div>
      </div>
    </div>
    <script src="/js/index.js"></script>
  </body>
</html>
