<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Configure Response</title>
    <link href="/styles.css" rel="stylesheet" />
  </head>
  <body class="bg-gradient-to-br from-blue-100 to-purple-100 min-h-screen flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg mx-4">
      <div class="bg-gradient-to-r from-blue-600 to-purple-600 text-white p-6 rounded-t-xl">
        <h2 class="text-2xl font-bold">Configure Response for: <%= configId || "N/A" %></h2>
      </div>
      <div class="p-6">
        <form method="POST" action="/config/<%= configId %>">
          <div class="mb-4">
            <label for="status" class="block text-sm font-medium text-gray-700 mb-1">Status Code</label>
            <select id="status" name="status" required class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="200" <%= responseConfig.status === 200 ? "selected" : "" %>>200 - OK</option>
              <option value="201" <%= responseConfig.status === 201 ? "selected" : "" %>>201 - Created</option>
              <option value="400" <%= responseConfig.status === 400 ? "selected" : "" %>>400 - Bad Request</option>
              <option value="404" <%= responseConfig.status === 404 ? "selected" : "" %>>404 - Not Found</option>
              <option value="500" <%= responseConfig.status === 500 ? "selected" : "" %>>500 - Internal Server Error</option>
            </select>
          </div>
          <div class="mb-4">
            <label for="contentType" class="block text-sm font-medium text-gray-700 mb-1">Response Type</label>
            <select id="contentType" name="contentType" required class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="text" <%= responseConfig.contentType === "text" ? "selected" : "" %>>Text</option>
              <option value="json" <%= responseConfig.contentType === "json" ? "selected" : "" %>>JSON</option>
              <option value="xml" <%= responseConfig.contentType === "xml" ? "selected" : "" %>>XML</option>
            </select>
          </div>
          <div class="mb-6">
            <label for="body" class="block text-sm font-medium text-gray-700 mb-1">Response Body</label>
            <textarea id="body" name="body" rows="4" required class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Enter response body..."><%= responseConfig.body %></textarea>
          </div>
          <div class="flex justify-between">
            <a href="/r/<%= configId %>" class="bg-gray-500 hover:bg-gray-700 text-white font-semibold py-2 px-4 rounded transition duration-200">Back</a>
            <button type="submit" class="bg-blue-600 hover:bg-blue-800 text-white font-semibold py-2 px-4 rounded transition duration-200">Save Configuration</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Toast container -->
    <div class="fixed top-4 right-4 z-50">
      <div id="liveToast" class="hidden bg-green-500 text-white px-6 py-4 rounded-lg shadow-lg">
        <div class="flex items-center justify-between">
          <div>Configuration saved successfully!</div>
          <button type="button" class="ml-4 text-white hover:text-gray-200" onclick="this.parentElement.parentElement.style.display='none'">
            ×
          </button>
        </div>
      </div>
    </div>

    <script>
      (function () {
        const params = new URLSearchParams(window.location.search);
        if (params.get("status") === "ok") {
          const toastEl = document.getElementById("liveToast");
          toastEl.style.display = "block";
          setTimeout(() => {
            toastEl.style.display = "none";
          }, 3000);
        }

        // Update textarea placeholder based on selected type
        const contentTypeEl = document.getElementById("contentType");
        const bodyEl = document.getElementById("body");
        function updatePlaceholder() {
          switch (contentTypeEl.value) {
            case "json":
              bodyEl.placeholder = '{"message": "Hello world"}';
              break;
            case "xml":
              bodyEl.placeholder = '<message>Hello world</message>';
              break;
            default:
              bodyEl.placeholder = "Enter plain text...";
              break;
          }
        }
        contentTypeEl.addEventListener("change", updatePlaceholder);
        updatePlaceholder();
      })();
    </script>
  </body>
</html>
