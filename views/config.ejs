<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Configure Response</title>
    <link href="/styles.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/jsoneditor/9.10.0/jsoneditor.min.css" rel="stylesheet" type="text/css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jsoneditor/9.10.0/jsoneditor.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/codemirror.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/xml/xml.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/codemirror.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/theme/monokai.min.css" rel="stylesheet">
  </head>
  <body class="bg-gradient-to-br from-blue-100 to-purple-100 min-h-screen p-5">
    <div class="container mx-auto max-w-4xl">
      <div class="bg-white rounded-xl shadow-2xl overflow-hidden">
        <div class="bg-gradient-to-r from-blue-600 to-purple-600 text-white p-6">
          <div class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <h2 class="text-2xl font-bold">Configure Response for: <%= configId || "N/A" %></h2>
          </div>
        </div>
        <div class="p-8">
          <form method="POST" action="/config/<%= configId %>" id="configForm" class="space-y-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Status Code</label>
              <div class="flex gap-4 items-start">
                <div class="flex-1">
                  <select id="status" name="status" required class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                    <option value="200" <%= responseConfig.status === 200 ? "selected" : "" %>>200 - OK</option>
                    <option value="201" <%= responseConfig.status === 201 ? "selected" : "" %>>201 - Created</option>
                    <option value="400" <%= responseConfig.status === 400 ? "selected" : "" %>>400 - Bad Request</option>
                    <option value="404" <%= responseConfig.status === 404 ? "selected" : "" %>>404 - Not Found</option>
                    <option value="500" <%= responseConfig.status === 500 ? "selected" : "" %>>500 - Internal Server Error</option>
                    <option value="custom" <%= ![200, 201, 400, 404, 500].includes(responseConfig.status) ? "selected" : "" %>>Other (Custom)</option>
                  </select>
                </div>
                <div id="customStatusContainer" class="<%= ![200, 201, 400, 404, 500].includes(responseConfig.status) ? "flex-1" : "hidden flex-1" %>">
                  <input
                    type="number"
                    id="customStatus"
                    min="100"
                    max="599"
                    value="<%= ![200, 201, 400, 404, 500].includes(responseConfig.status) ? responseConfig.status : "" %>"
                    placeholder="Enter status code (100-599)"
                    class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors <%= ![200, 201, 400, 404, 500].includes(responseConfig.status) ? 'border-green-500' : '' %>"
                  >
                  <p class="mt-1 text-sm text-gray-500">Enter a valid HTTP status code (100-599)</p>
                </div>
              </div>
            </div>

            <div>
              <label for="contentType" class="block text-sm font-medium text-gray-700 mb-1">Response Type</label>
              <select id="contentType" name="contentType" required class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                <option value="text" <%= responseConfig.contentType === "text" ? "selected" : "" %>>Text</option>
                <option value="json" <%= responseConfig.contentType === "json" ? "selected" : "" %>>JSON</option>
                <option value="xml" <%= responseConfig.contentType === "xml" ? "selected" : "" %>>XML</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Response Body</label>
              <div id="bodyContainer" class="border border-gray-300 rounded-lg overflow-hidden">
                <div id="jsonEditor" style="height: 400px;" class="hidden"></div>
                <textarea
                  id="body"
                  name="body"
                  rows="6"
                  required
                  class="w-full px-4 py-3 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors font-mono text-sm"
                  placeholder="Enter response body..."
                ><%= responseConfig.body %></textarea>
              </div>
              <div id="validationMessage" class="mt-2 text-sm"></div>
            </div>

            <div class="flex justify-between pt-4">
              <a href="/explorer/<%= configId %>" class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors focus:outline-none focus:ring-2 focus:ring-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back
              </a>
              <button type="submit" id="submitBtn" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Save Configuration
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Toast container -->
    <div class="fixed top-4 right-4 z-50">
      <div id="liveToast" class="hidden transform transition-all duration-300">
        <div class="bg-green-500 text-white px-6 py-4 rounded-lg shadow-xl flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>Configuration saved successfully!</span>
          <button type="button" class="ml-6 hover:text-gray-200 transition-colors" onclick="this.parentElement.parentElement.style.display='none'">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <script>
      (function () {
        const params = new URLSearchParams(window.location.search);
        const statusSelect = document.getElementById('status');
        const customStatusContainer = document.getElementById('customStatusContainer');
        const customStatusInput = document.getElementById('customStatus');
        const contentTypeEl = document.getElementById('contentType');
        const bodyEl = document.getElementById('body');
        const bodyContainer = document.getElementById('bodyContainer');
        const jsonEditorContainer = document.getElementById('jsonEditor');
        const validationMessage = document.getElementById('validationMessage');
        const submitBtn = document.getElementById('submitBtn');
        const configForm = document.getElementById('configForm');
        let jsonEditor = null;
        let xmlEditor = null;

        // Initialize status value from loaded config
        const initialStatusValue = parseInt(customStatusInput.value);
        if (initialStatusValue && ![200, 201, 400, 404, 500].includes(initialStatusValue)) {
          statusSelect.value = 'custom';
          statusSelect.name = '';
          customStatusContainer.classList.remove('hidden');
          customStatusInput.required = true;
          customStatusInput.classList.add('border-green-500');
        }

        // Status code handling
        statusSelect.addEventListener('change', function() {
          if (this.value === 'custom') {
            customStatusContainer.classList.remove('hidden');
            customStatusInput.required = true;
            statusSelect.name = '';
            customStatusInput.focus();
            if (!customStatusInput.value) {
              // Only set the initial value if the input is empty
              customStatusInput.value = initialStatusValue || '';
            }
          } else {
            customStatusContainer.classList.add('hidden');
            customStatusInput.required = false;
            statusSelect.name = 'status';
          }
        });

        customStatusInput.addEventListener('input', function() {
          const value = parseInt(this.value);
          if (value >= 100 && value <= 599) {
            this.classList.remove('border-red-500');
            this.classList.add('border-green-500');
          } else {
            this.classList.remove('border-green-500');
            this.classList.add('border-red-500');
          }
        });

        // JSON Editor setup
        function setupJsonEditor() {
          if (!jsonEditor) {
            const options = {
              mode: 'code',
              modes: ['code', 'tree'],
              onValidate: function(json) {
                try {
                  if (!json) {
                    validationMessage.textContent = 'JSON is empty';
                    validationMessage.className = 'mt-2 text-sm text-yellow-600';
                    return;
                  }
                  JSON.stringify(json);
                  validationMessage.textContent = 'Valid JSON ✓';
                  validationMessage.className = 'mt-2 text-sm text-green-600';
                  submitBtn.disabled = false;
                } catch (err) {
                  validationMessage.textContent = 'Invalid JSON: ' + err.message;
                  validationMessage.className = 'mt-2 text-sm text-red-600';
                  submitBtn.disabled = true;
                }
              }
            };
            jsonEditor = new JSONEditor(jsonEditorContainer, options);
          }
        }

        // XML Editor setup
        function setupXmlEditor() {
          if (!xmlEditor) {
            xmlEditor = CodeMirror.fromTextArea(bodyEl, {
              mode: 'xml',
              theme: 'monokai',
              lineNumbers: true,
              autoCloseTags: true,
              matchTags: {bothTags: true},
              extraKeys: {"Ctrl-Q": function(cm){ cm.foldCode(cm.getCursor()); }},
              foldGutter: true,
              gutters: ["CodeMirror-linenumbers", "CodeMirror-foldgutter"],
              lineWrapping: true,
              height: "400px"
            });
            xmlEditor.setSize(null, 400);
          }
          return xmlEditor;
        }

        // XML Validation
        function validateXML(xmlString) {
          const parser = new DOMParser();
          const doc = parser.parseFromString(xmlString, 'application/xml');
          const errorNode = doc.querySelector('parsererror');
          if (errorNode) {
            return {
              valid: false,
              error: errorNode.textContent
            };
          }
          return {
            valid: true
          };
        }

        function formatXML(xmlString) {
          const parser = new DOMParser();
          const doc = parser.parseFromString(xmlString, 'application/xml');
          const serializer = new XMLSerializer();
          const formatted = serializer.serializeToString(doc)
            .replace(/>(?:\r\n|\n|\r)?</g, '>\n<')
            .replace(/(<[^\/>]*>)(?:\r\n|\n|\r)?/g, '$1\n')
            .replace(/(<\/[^>]+>)(?:\r\n|\n|\r)?/g, '$1\n')
            .split('\n')
            .map(line => line.trim())
            .filter(line => line.length > 0)
            .map(line => '  '.repeat(line.split('<').length - 1) + line)
            .join('\n');
          return formatted;
        }

        function updateBodyEditor() {
          const contentType = contentTypeEl.value;

          // Hide all editors first
          if (xmlEditor) xmlEditor.getWrapperElement().style.display = 'none';
          if (jsonEditor) jsonEditorContainer.classList.add('hidden');
          bodyEl.style.display = 'none';

          switch(contentType) {
            case 'json':
              setupJsonEditor();
              jsonEditorContainer.classList.remove('hidden');
              try {
                const currentValue = bodyEl.value.trim();
                const jsonValue = currentValue ? JSON.parse(currentValue) : {};
                jsonEditor.set(jsonValue);
              } catch (e) {
                jsonEditor.set({});
              }
              break;

            case 'xml':
              const editor = setupXmlEditor();
              editor.getWrapperElement().style.display = 'block';
              if (!editor.getValue()) {
                editor.setValue(`<?xml version="1.0" encoding="UTF-8"?>\n<root>\n  <message>Hello World</message>\n</root>`);
              }
              // Format XML on load
              try {
                const formatted = formatXML(editor.getValue());
                editor.setValue(formatted);
              } catch (e) {
                console.error('XML formatting error:', e);
              }
              break;

            default: // text
              bodyEl.style.display = 'block';
              break;
          }
        }

        // Content type change handler
        contentTypeEl.addEventListener('change', updateBodyEditor);

        // Form submission
        configForm.addEventListener('submit', function(e) {
          e.preventDefault();

          // Validate custom status if selected
          if (statusSelect.value === 'custom') {
            const statusValue = parseInt(customStatusInput.value);
            if (!(statusValue >= 100 && statusValue <= 599)) {
              alert('Please enter a valid HTTP status code (100-599)');
              return;
            }
            const hiddenStatus = document.createElement('input');
            hiddenStatus.type = 'hidden';
            hiddenStatus.name = 'status';
            hiddenStatus.value = statusValue;
            this.appendChild(hiddenStatus);
          }

          // Handle different content types
          switch(contentTypeEl.value) {
            case 'json':
              try {
                const jsonValue = jsonEditor.get();
                bodyEl.value = JSON.stringify(jsonValue, null, 2);
              } catch (err) {
                alert('Please enter valid JSON');
                return;
              }
              break;

            case 'xml':
              const xmlValue = xmlEditor.getValue();
              const xmlValidation = validateXML(xmlValue);
              if (!xmlValidation.valid) {
                alert('Invalid XML: ' + xmlValidation.error);
                return;
              }
              bodyEl.value = formatXML(xmlValue);
              break;
          }

          this.submit();
        });

        // Initialize
        if (params.get("status") === "ok") {
          const toastEl = document.getElementById("liveToast");
          toastEl.style.display = "block";
          setTimeout(() => {
            toastEl.style.display = "none";
          }, 3000);
        }

        // Initial setup
        updateBodyEditor();

        // If we have a custom status code loaded, ensure the input has the correct validation styling
        if (customStatusInput.value) {
          const value = parseInt(customStatusInput.value);
          if (value >= 100 && value <= 599) {
            customStatusInput.classList.remove('border-red-500');
            customStatusInput.classList.add('border-green-500');
          }
        }
      })();
    </script>
  </body>
</html>
