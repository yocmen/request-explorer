<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Configure Response</title>
    <link href="/styles.css" rel="stylesheet" />
  </head>
  <body class="bg-gradient-to-br from-blue-100 to-purple-100 min-h-screen p-5">
    <div class="container mx-auto max-w-4xl">
      <div class="bg-white rounded-xl shadow-2xl overflow-hidden">
        <div class="bg-gradient-to-r from-blue-600 to-purple-600 text-white p-6">
          <div class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <h2 class="text-2xl font-bold">Configure Response for: <%= configId || "N/A" %></h2>
          </div>
        </div>
        <div class="p-8">
          <form method="POST" action="/config/<%= configId %>">
            <div class="space-y-6">
              <div>
                <label for="status" class="block text-sm font-medium text-gray-700 mb-1">Status Code</label>
                <select id="status" name="status" required class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="200" <%= responseConfig.status === 200 ? "selected" : "" %>>200 - OK</option>
                  <option value="201" <%= responseConfig.status === 201 ? "selected" : "" %>>201 - Created</option>
                  <option value="400" <%= responseConfig.status === 400 ? "selected" : "" %>>400 - Bad Request</option>
                  <option value="404" <%= responseConfig.status === 404 ? "selected" : "" %>>404 - Not Found</option>
                  <option value="500" <%= responseConfig.status === 500 ? "selected" : "" %>>500 - Internal Server Error</option>
                </select>
              </div>
              
              <div>
                <label for="contentType" class="block text-sm font-medium text-gray-700 mb-1">Response Type</label>
                <select id="contentType" name="contentType" required class="w-full border border-gray-300 rounded-lg px-4 py-2.5 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="text" <%= responseConfig.contentType === "text" ? "selected" : "" %>>Text</option>
                  <option value="json" <%= responseConfig.contentType === "json" ? "selected" : "" %>>JSON</option>
                  <option value="xml" <%= responseConfig.contentType === "xml" ? "selected" : "" %>>XML</option>
                </select>
              </div>
              
              <div>
                <label for="body" class="block text-sm font-medium text-gray-700 mb-1">Response Body</label>
                <textarea 
                  id="body" 
                  name="body" 
                  rows="6" 
                  required 
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors font-mono text-sm"
                  placeholder="Enter response body..."><%= responseConfig.body %></textarea>
              </div>

              <div class="flex justify-between pt-4">
                <a href="/r/<%= configId %>" class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors focus:outline-none focus:ring-2 focus:ring-gray-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                  </svg>
                  Back
                </a>
                <button type="submit" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Save Configuration
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Toast container -->
    <div class="fixed top-4 right-4 z-50">
      <div id="liveToast" class="hidden transform transition-all duration-300">
        <div class="bg-green-500 text-white px-6 py-4 rounded-lg shadow-xl flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>Configuration saved successfully!</span>
          <button type="button" class="ml-6 hover:text-gray-200 transition-colors" onclick="this.parentElement.parentElement.style.display='none'">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <script>
      (function () {
        const params = new URLSearchParams(window.location.search);
        if (params.get("status") === "ok") {
          const toastEl = document.getElementById("liveToast");
          toastEl.style.display = "block";
          setTimeout(() => {
            toastEl.style.display = "none";
          }, 3000);
        }

        // Update textarea placeholder based on selected type
        const contentTypeEl = document.getElementById("contentType");
        const bodyEl = document.getElementById("body");
        function updatePlaceholder() {
          switch (contentTypeEl.value) {
            case "json":
              bodyEl.placeholder = '{"message": "Hello world"}';
              break;
            case "xml":
              bodyEl.placeholder = '<message>Hello world</message>';
              break;
            default:
              bodyEl.placeholder = "Enter plain text...";
              break;
          }
        }
        contentTypeEl.addEventListener("change", updatePlaceholder);
        updatePlaceholder();
      })();
    </script>
  </body>
</html>
