<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Request Explorer - <%= id %></title>
    <link href="/styles.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
  </head>
  <body class="bg-gray-100">
    <div class="container mx-auto p-8" id="requestsContainer">
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold" data-room-id="<%= id %>">Requests for ID: <%= id %></h1>
        <a class="bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded transition duration-200" href="/config/<%= id %>">
          <i class="bi-gear"></i>
        </a>
      </div>
    </div>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/explorer.js"></script>
  </body>
</html>
